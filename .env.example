# Copy to `.env`, then: docker compose up --build
SECRET_KEY=change-me-to-a-long-random-string
POSTGRES_DB=allinpart
POSTGRES_USER=allinpart
POSTGRES_PASSWORD=change-me
ALLOWED_HOSTS=allinpart.com,www.allinpart.com
# Primary key in django_site (python manage.py shell: Site.objects.values_list("id", flat=True))
SITE_ID=3
CSRF_TRUSTED_ORIGINS=https://allinpart.com,https://www.allinpart.com
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# Place TLS certs in docker/nginx/ssl/ (not committed to git):
#   fullchain.pem
#   allinpart.private.key
