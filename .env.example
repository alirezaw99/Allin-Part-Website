# Copy to `.env`, then: docker compose up --build
SECRET_KEY=change-me-to-a-long-random-string
POSTGRES_DB=allinpart
POSTGRES_USER=allinpart
POSTGRES_PASSWORD=change-me
WEB_PORT=8080
ALLOWED_HOSTS=localhost,127.0.0.1
# Primary key in django_site (python manage.py shell: Site.objects.values_list("id", flat=True))
SITE_ID=3
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
